{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"forceConsistentCasingInFileNames": true,
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"declarationMap": true,
		"strict": true,
		"esModuleInterop": true,
		"noUncheckedSideEffectImports": true,
		"skipLibCheck": true
	},
	"include": ["src", "scripts"]
}
